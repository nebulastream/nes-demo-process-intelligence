# name: inference/InferModelAutoModelFromBase64RawTensor.test
# description: ML model inference with the real auto-model using FROM_BASE64 to decode a base64-encoded raw float tensor
# groups: [Inference]

CREATE LOGICAL SOURCE stream(data VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE


CREATE MODEL auto_vi ('../../auto-model/pipe_staple_pca.onnx')
INPUT (pixels VARSIZED)
OUTPUT (anomaly_score FLOAT32);

CREATE SINK result(ANOMALY_SCORE FLOAT32 NOT NULL) TYPE File;

SELECT anomaly_score
FROM MODEL_INFERENCE(auto_vi, (SELECT FROM_BASE64(data) AS pixels FROM stream))
INTO result;
----
0.050982
