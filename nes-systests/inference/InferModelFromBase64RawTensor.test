# name: inference/InferModelFromBase64RawTensor.test
# description: ML model inference with MODEL_INFERENCE using FROM_BASE64 to decode a base64-encoded raw float tensor
# groups: [Inference]

CREATE LOGICAL SOURCE stream(data VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE


CREATE MODEL tiny_reduction ('../../nes-inference/tests/testdata/tiny_reduction.onnx')
INPUT (input_blob VARSIZED)
OUTPUT (o0 FLOAT32, o1 FLOAT32, o2 FLOAT32, o3 FLOAT32, o4 FLOAT32, o5 FLOAT32, o6 FLOAT32, o7 FLOAT32, o8 FLOAT32, o9 FLOAT32);

CREATE SINK result(O0 FLOAT32 NOT NULL, O1 FLOAT32 NOT NULL, O2 FLOAT32 NOT NULL, O3 FLOAT32 NOT NULL, O4 FLOAT32 NOT NULL, O5 FLOAT32 NOT NULL, O6 FLOAT32 NOT NULL, O7 FLOAT32 NOT NULL, O8 FLOAT32 NOT NULL, O9 FLOAT32 NOT NULL) TYPE File;

SELECT o0, o1, o2, o3, o4, o5, o6, o7, o8, o9
FROM MODEL_INFERENCE(tiny_reduction, (SELECT FROM_BASE64(data) AS input_blob FROM stream))
INTO result;
----
0.000000,0.000000,0.000000,0.000000,0.000000,0.000000,0.000000,0.000000,0.000000,0.000000
